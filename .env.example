# ===========================================
# NOTÍCIA DA HORA — Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com dados reais

# --- Banco de Dados (PostgreSQL) ---
DATABASE_URL="postgresql://noticia_user:SENHA_FORTE@localhost:5432/noticia_da_hora"

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview

# --- Instagram Graph API ---
# Obtenha em: https://developers.facebook.com
# Use INSTAGRAM_ACCOUNTS para gerenciar múltiplas contas (formato JSON)
INSTAGRAM_ACCOUNTS='[{"id":"principal","name":"Conta Principal","userId":"17841xxxxxxxxxx","accessToken":"EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"},{"id":"promo","name":"Promoção de Hoje","userId":"17841xxxxxxxxxx","accessToken":"EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"}]'

# Variáveis legadas mantidas para compatibilidade (serão ignoradas se INSTAGRAM_ACCOUNTS estiver configurado)
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_USER_ID=17841xxxxxxxxxx

# --- LinkedIn API ---
# Crie em: https://developer.linkedin.com
LINKEDIN_ACCESS_TOKEN=AQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_PERSON_ID=urn:li:person:xxxxxxxxxx

# --- Evolution API (WhatsApp) ---
# Sua Evolution API na VPS Hertnez
EVOLUTION_API_URL=http://SEU_IP_VPS:8080
EVOLUTION_API_KEY=SUA_CHAVE_SECRETA
EVOLUTION_INSTANCE=noticia-da-hora
WHATSAPP_DESTINATION=5571987841067

# --- Alertas de Erro ---
# Resend: https://resend.com (plano gratuito disponível)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL=seu@email.com
ALERT_WHATSAPP=5571987841067

# --- Autenticação do Dashboard ---
NEXTAUTH_SECRET=GERE_COM_openssl_rand_-base64_32
NEXTAUTH_URL=http://localhost:3000
DASHBOARD_PASSWORD=SUA_SENHA_SEGURA_AQUI

# --- Scheduler ---
# Frequência de coleta em minutos (padrão: 60)
SCRAPE_INTERVAL_MINUTES=60

# --- Ambiente ---
NODE_ENV=development
